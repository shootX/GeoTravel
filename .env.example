# VITE_MAPBOX_ACCESS_TOKEN: Mapbox public access token for the route map.
VITE_MAPBOX_ACCESS_TOKEN="YOUR_MAPBOX_ACCESS_TOKEN"

# APP_URL: Base URL for OAuth callbacks and redirects.
APP_URL="http://localhost:3000"

# Database (SQLite)
DATABASE_URL="file:./dev.db"

# JWT secrets — generate with: openssl rand -hex 64
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars-long"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars-long"

# Google OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Facebook OAuth — https://developers.facebook.com/
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""

# Demo user (created via npm run db:seed)
# Email: demo@voya.ai  |  Password: Demo1234

# Admin CMS user (created via npm run db:seed)
# Email: admin@voya.ai  |  Password: Admin1234
# CMS URL: http://localhost:3000/admin

# GEMINI_API_KEY: Google Gemini API key
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional AI provider keys (managed in Admin → AI Planner)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
MISTRAL_API_KEY=""
DEEPSEEK_API_KEY=""
GROQ_API_KEY=""
